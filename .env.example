# Copy this file to .env and fill in real values. NEVER commit the real .env.
# Generate a SECRET_KEY with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

# Django Settings
SECRET_KEY=replace-with-a-50-char-random-secret
DEBUG=False
ALLOWED_HOSTS=suderra.com,www.suderra.com

# Email Settings (use a dedicated app password, store it ONLY here)
EMAIL_HOST_USER=your-sender@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=your-sender@gmail.com
CONTACT_RECIPIENT=you@example.com

# Brevo (Sendinblue) Newsletter — optional
BREVO_API_KEY=
BREVO_LIST_ID=
